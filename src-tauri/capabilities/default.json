{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window, tool windows, and the quick switcher",
  "windows": ["main", "tool-*", "quick-switcher"],
  "permissions": [
    "core:default",
    "opener:default",
    "core:window:allow-hide",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:window:allow-close"
  ]
}
